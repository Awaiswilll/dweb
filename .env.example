# ─── AI Provider API Keys ─────────────────────────────────────
# dweb supports multiple AI providers. Set keys for the ones you use.
# Ollama runs locally and needs no API key.

# OpenAI
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic Claude
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Together AI
# Get your key at: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Groq
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Cloud Provider Credentials ───────────────────────────────

# AWS (for Cloud Shift deployment)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Netlify (for one-click deploy)
# Get your token at: https://app.netlify.com/user/applications
NETLIFY_AUTH_TOKEN=

# Vercel (for one-click deploy)
# Get your token at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# ─── GitHub OAuth ─────────────────────────────────────────────
# Built-in device flow works without a key.
# Create an OAuth app at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
